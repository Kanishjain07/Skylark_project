# ---- Monday.com ----
# Create a token at: monday.com > Avatar > Developers > My Access Tokens
MONDAY_API_TOKEN=your_monday_api_token_here

# Board IDs for the two imported boards.
# Find the ID in the board URL: monday.com/boards/<BOARD_ID>
MONDAY_WORK_ORDERS_BOARD_ID=0000000000
MONDAY_DEALS_BOARD_ID=0000000000

# ---- Groq (OpenAI-compatible) ----
# Get a key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b

# ---- App ----
# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cache monday.com board data for this many seconds (reduces API calls)
BOARD_CACHE_TTL_SECONDS=120
